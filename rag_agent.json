      "parameters": {
        "jsCode": "const searchResults = $input.all();\n\n// Webhook data అన్ని ways లో try చేయి\nconst webhookData = $('Webhook1').first().json;\nconst question = webhookData.body?.question || \n                 webhookData.question || \n                 \"What is AI?\";\n\nconst context = searchResults\n  .map(item => item.json.content)\n  .join(' ');\n\nconst prompt = \"You are a helpful assistant. Answer based ONLY on this context: \" + \n  context + \" Question: \" + question;\n\nreturn [{\n  json: { prompt, question, context }\n}];"
      },
