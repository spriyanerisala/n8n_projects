    {
      "parameters": {
        "jsCode": "const embedding = $input.first().json.data[0].embedding;\nconst content = $('Code in JavaScript').first().json.content;\n\n// Content ని JSON safe చేయి\nconst safeContent = content\n  .replace(/\\\\/g, '\\\\\\\\')\n  .replace(/\"/g, '\\\\\"')\n  .replace(/\\n/g, ' ')\n  .replace(/\\r/g, ' ')\n  .replace(/\\t/g, ' ');\n\nreturn [{\n  json: {\n    body: {\n      content: safeContent,\n      embedding: embedding\n    }\n  }\n}];"
      },
